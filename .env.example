# IP Network Newsletter Agent — 환경 변수 예시
# 사용법: 이 파일을 .env 로 복사한 뒤 실제 값으로 수정
#   copy .env.example .env        (Windows)
#   cp .env.example .env          (macOS/Linux)

# ── LLM (필수) ───────────────────────────────────────
OPENAI_API_KEY=sk-...

# LiteLLM / a15t 등 게이트웨이 사용 시 (회사 API Key 방식)
# OPENAI_API_BASE=https://your-litellm-gateway/v1
# OPENAI_CHAT_MODEL=azure/openai/gpt-4.1-mini-2025-04-14-gs

# OpenAI 직접 호출 시 모델명 (게이트웨이 미사용)
# OPENAI_MODEL_PRIMARY=gpt-4o-mini

# temperature (선택) — gpt-5 계열은 0 미지원, 미설정 시 모델 기본값 사용
# OPENAI_TEMPERATURE=1

# 리뷰/bias structured output (선택)
# OPENAI_MAX_COMPLETION_TOKENS=4096
# OPENAI_TIMEOUT=120

# 모델명 우선순위: OPENAI_CHAT_MODEL → OPENAI_MODEL_PRIMARY → gpt-4o-mini
# 연결 테스트: python test_llm_api.py

# ── Obsidian Vault (선택) ────────────────────────────
# 미설정 시 git clone 위치의 vault/ 폴더를 자동 사용합니다.
# 별도 Obsidian Vault 경로를 쓸 때만 설정하세요.
# OBSIDIAN_VAULT_PATH=C:/path/to/your/vault

# ── Tavily (선택) ────────────────────────────────────
# expansion search · Kentik/TM Forum 본문 Extract · 웹 검색 보강
# TAVILY_API_KEY=tvly-...

# ── MVP 시연용 상한 (선택, 미설정 시 제한 없음) ───────
# 소스당 fetch 최대 기사 수 (sources.yaml 값과 min 적용)
# MVP_MAX_ARTICLES_PER_SOURCE=4

# ── LangSmith (선택 — LLM 트레이싱) ──────────────────
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=ip-newsletter-agent
